# ========================================
# AI Agent (Backend) Environment Variables
# ========================================

# The port the backend server runs on (Default: 3000)
PORT=3000

# The URL of your local Ollama instance
OLLAMA_API_URL="http://localhost:11434"

# The Ollama model to use (e.g., gemma2, gemma2:2b, llama3)
OLLAMA_MODEL="gemma2"

# Database connection string for Prisma (SQLite by default)
DATABASE_URL="file:./dev.db"

# LLM Context Window Strategy: 'LARGE_MODEL' or 'SMALL_MODEL'
# - LARGE_MODEL: Maintains longer context history (last 20 messages)
# - SMALL_MODEL: Truncates history to 4 messages to save compute on small VMs
LLM_PROFILE="LARGE_MODEL"

# Enable dynamic tool categorization/layering using LLM (true/false)
ENABLE_TOOLS_LAYERING="true"

# Enable the AI's ability to write, test, and register its own tools (true/false)
ENABLE_SELF_IMPROVEMENT="true"

# Comma-separated list of tool names you want to explicitly disable
# Example: DISABLED_TOOLS="human_interruption_prompt,fetch_web_resource"
DISABLED_TOOLS=""

# Set to true to bypass Docker sandbox completely (for environments where Docker isn't installed)
DISABLE_DOCKER="false"
